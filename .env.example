COINGECKO_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rails sibling service base URL (server-only, never NEXT_PUBLIC_).
# Default for local development: http://127.0.0.1:3001
# Vercel sets this to the deployed Render Rails URL.
RAILS_BASE_URL=http://127.0.0.1:3001

# --- Local Rails Postgres (development/test) ---
# Either set DATABASE_URL or individual PG* vars.
# These are NOT used by Next.js; they belong to the Rails app only.
# DATABASE_URL=postgresql://localhost:5432/tokenscope_development
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=tokenscope_development

# --- Production secret ownership (DO NOT set here) ---
# Render stores the Neon connection string as DATABASE_URL.
# Vercel stores RAILS_BASE_URL (the Render Rails URL).
# Neon Auth is disabled. Neon is used only as a managed Postgres provider.
